# AI Gateway — set on Vercel via `vercel env pull` after linking the project,
# or copy this file to `.env.local` for local development.
AI_GATEWAY_API_KEY=

# Vercel Sandbox auth — required to spawn microVMs from the Route Handler.
# Generate at https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Public Git source the sandbox will clone. Defaults to this repo's origin.
SANDBOX_GIT_URL=https://github.com/DanielT777/llm-fuse.git
SANDBOX_GIT_REVISION=main

# Set to "1" to allow the demo to run the CLI locally instead of in Sandbox
# (useful for testing without Vercel credentials).
LLMFUSE_LOCAL_MODE=0
