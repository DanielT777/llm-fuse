{
  "name": "@llm-fuse/fuse",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "llmfuse-probe": "./dist/probe.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/probe.js",
