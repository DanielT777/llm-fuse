  },
  "dependencies": {
    "@llm-fuse/core": "workspace:*"
  },
  "optionalDependencies": {
    "fuse-native": "^2.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
